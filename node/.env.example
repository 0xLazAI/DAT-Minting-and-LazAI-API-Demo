# Copy this file to .env and fill in your actual values

# Your Ethereum private key (without 0x prefix)
# Get this from your wallet (MetaMask, etc.)
PRIVATE_KEY=your_64_character_hex_private_key_here

# Your Pinata Cloud JWT token
# Get this from https://pinata.cloud after creating an API key
IPFS_JWT=your_pinata_jwt_token_here